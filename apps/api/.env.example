PORT=3000
DATABASE_URL=postgresql://lexiroot:password@localhost:5432/lexiroot
JWT_SECRET=
JWT_EXPIRES_IN=7d
# Google OAuth client IDs accepted as ID-token audiences for /auth/google.
# Web client ID doubles as the mobile app's webClientId.
GOOGLE_CLIENT_ID_WEB=
GOOGLE_CLIENT_ID_IOS=
# --- Payments / subscriptions ---
# Active provider registry: stripe | paystack | apple_iap (only stripe is live).
PAYMENTS_DEFAULT_PROVIDER=stripe
# Stripe: use test-mode keys (sk_test_...) in development.
STRIPE_SECRET_KEY=
# From `stripe listen` (whsec_...) locally, or the dashboard endpoint secret.
STRIPE_WEBHOOK_SECRET=
APPLE_IAP_SHARED_SECRET=
# Where hosted checkout returns after success/cancel — these are pages on the
# marketing website (apps/web), which bounce mobile back into the app. In prod
# use the website domain, e.g. https://lexiroot.app/subscription/success.
CHECKOUT_SUCCESS_URL=http://localhost:5174/subscription/success
CHECKOUT_CANCEL_URL=http://localhost:5174/subscription/cancel
# Days a past-due / cancelled subscription keeps access past period end.
SUBSCRIPTION_GRACE_DAYS=3
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
EXPO_PUSH_ACCESS_TOKEN=
RESEND_API_KEY=
EMAIL_FROM=LexiRoot <onboarding@resend.dev>
# Base URL of the admin dashboard, used to build admin invitation links.
ADMIN_URL=http://localhost:5173
