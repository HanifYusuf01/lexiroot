{
  "name": "@lexiroot/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "prestart": "pnpm --filter @lexiroot/shared build",
    "start": "nest start",
    "prestart:dev": "pnpm --filter @lexiroot/shared build",
    "start:dev": "nest start --watch",
    "prestart:prod": "pnpm --filter @lexiroot/shared build",
    "start:prod": "node dist/main",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typeorm": "typeorm-ts-node-commonjs",
    "premigration:run": "pnpm --filter @lexiroot/shared build",
    "migration:run": "pnpm typeorm migration:run -d src/database/data-source.ts",
    "migration:revert": "pnpm typeorm migration:revert -d src/database/data-source.ts",
    "migration:generate": "pnpm typeorm migration:generate -d src/database/data-source.ts",
    "migration:create": "pnpm typeorm migration:create"
  },
  "dependencies": {
    "@lexiroot/shared": "workspace:*",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/schedule": "^4.1.0",
    "@nestjs/typeorm": "^10.0.2",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cloudinary": "^2.10.0",
    "dotenv": "^17.4.2",
    "expo-server-sdk": "^6.1.0",
    "google-auth-library": "^10.9.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "stripe": "^22.3.0",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20.14.0",
    "@types/passport-jwt": "^4.0.1",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.11.0"
  }
}
