{
  "expo": {
    "name": "LexiRoot",
    "slug": "lexiroot",
    "scheme": "lexiroot",
    "version": "0.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lexiroot.mobile"
    },
    "android": {
      "package": "com.lexiroot.mobile"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
