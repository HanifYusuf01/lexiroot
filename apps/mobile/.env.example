# Override API base URL (otherwise auto-derived from Expo dev server hostUri)
# Local API:      EXPO_PUBLIC_API_URL=http://localhost:3000
# Deployed API:   EXPO_PUBLIC_API_URL=https://api.lexiroot.app
# EXPO_PUBLIC_API_URL=https://api.lexiroot.app

# Google sign-in OAuth client IDs (from Google Cloud Console).
# Web client ID must match the backend's GOOGLE_CLIENT_ID_WEB (token audience).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
